{
  "name": "@wenit/mysql-mcp-server",
  "version": "1.1.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mysql-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspector": "npx -y @modelcontextprotocol/inspector node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"{src,.github}/**/*.{ts,js,json,yml,yaml,md}\"",
    "format:check": "prettier --check \"{src,.github}/**/*.{ts,js,json,yml,yaml,md}\"",
    "test": "node --test --test-name-pattern=. test/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mysql",
    "database",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "author": "wenit",
  "license": "MIT",
  "description": "MySQL MCP Server - 通过 MCP 协议操作 MySQL 数据库",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yclenove/mysql-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/yclenove/mysql-mcp-server/issues"
  },
  "homepage": "https://github.com/yclenove/mysql-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.7",
    "mysql2": "^3.19.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
