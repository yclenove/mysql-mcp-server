# 复制为 .env 并填写；勿将 .env 提交到 Git
#
# 方式 A：分项配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
# 可选：限制可切换/可列举的库（逗号分隔，仅字母数字下划线）；不设置则不限制
# MYSQL_DATABASE_ALLOWLIST=db1,db2
#
# MCP：schema/overview 资源最多展开多少张表的列（默认 50；0=仅表名）
# MCP_SCHEMA_OVERVIEW_MAX_TABLES=50
#
# 多 DSN（JSON 数组）；默认连接仍为上面 MYSQL_* / MYSQL_URL
# MYSQL_MCP_EXTRA_CONNECTIONS=[{"id":"replica","url":"mysql://user:pass@127.0.0.1:3306/db"}]
# MYSQL_MCP_CONNECTION_ID=default
#
# 运维工具（可选）
# MYSQL_MCP_OPS_TOOLS=false
# MYSQL_MCP_KILL_QUERY=false
# MYSQL_MCP_READ_AUDIT_TOOL=false
# MYSQL_MCP_PROCESS_LIST_MAX=100
# MYSQL_MCP_READ_SLOW_LOG=false
# MYSQL_MCP_SLOW_LOG_PATH=/var/log/mysql/slow.log
#
# 只读时会话级 transaction_read_only（MYSQL_READONLY=true 时自动）
# 额外 DSN 默认库与白名单：MYSQL_MCP_VALIDATE_EXTRA_CONNECTIONS=true
# MCP_QUERY_RESULT_HINT=true
# MYSQL_MCP_EXPLAIN_JSON=true
#
# 方式 B：连接串（与方式 A 二选一即可；密码含特殊字符请 URL 编码）
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/your_database
# 或与部分生态兼容的别名：
# MYSQL_CONNECTION_STRING=mysql://user:password@127.0.0.1:3306/your_database
