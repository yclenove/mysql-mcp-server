# MySQL 连接配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=test

# 可选：连接池配置
MYSQL_CONNECTION_LIMIT=10
MYSQL_QUEUE_LIMIT=0
MYSQL_TIMEOUT=60000
MYSQL_QUERY_TIMEOUT=30000
MYSQL_RETRY_COUNT=2
MYSQL_RETRY_DELAY_MS=200
MYSQL_MAX_ROWS=100

# 安全设置
# 设置为 true 时只允许 SELECT 查询
MYSQL_READONLY=false

# 调试设置
# 设置为 true 时返回 executionTime 等额外信息
# MCP_DEBUG=false

# 审计日志（可选）
# 设置文件路径后，所有 SQL 执行都会记录到该文件
# MCP_AUDIT_LOG=./audit.log

# SSL 配置（可选）
# MYSQL_SSL_CA=/path/to/ca.pem
# MYSQL_SSL_CERT=/path/to/client-cert.pem
# MYSQL_SSL_KEY=/path/to/client-key.pem
